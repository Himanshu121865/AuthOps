// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Framework {
  NEXTJS
  NUXTJS
  REMIX
  SVELTEKIT
  ASTRO
  OTHER
}

model User {
  id        String   @id @default(uuid())
  authOId   String   @unique
  email     String   @unique
  username  String  @unique
  telegramUserId String   @unique 
  telegramChatId String   @unique
  vercelAcessToken String
  preferredFramework Framework
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastActiveAt DateTime @default(now())
  
}

enum Provider {
  GITHUB
  GITLAB
  BITBUCKET
}

model TokenVaultMapping {
  id      String   @id @default(uuid())
  userId    String   
  provider Provider
  providerUserId String
  connectionName String
  scopes String[]
  lastResfreshedAt DateTime @default(now())
  createdAt DateTime @default(now())
  isActive Boolean @default(true)
}

enum StatusOfWorkFlowExecution {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model WorkFlowExecution {
  id String @id @default(uuid())
  projectId String
  userId String
  inngestRunId String
  status StatusOfWorkFlowExecution
  currentStep String 
  startedAt DateTime @default(now())
  completedAt DateTime?
  errorMessage String?
  retryCount Int @default(0)
}

model AudiTlog {
  id String @id @default(uuid())
  userId String
  action String
  resourceType String
  resourceId String
  metadata Json
  ipAddress String
  userAgent String
  timestamp DateTime @default(now())
}



model ApprovalRequest {
  id String @id @default(uuid())
  workflowExecutionId String @default(uuid())
  userId String @default(uuid())
  civaAuthReqid String 
  requestDetails Json
  status StatusOfWorkFlowExecution
  createdAt DateTime @default(now())
  respondedAt DateTime?
  expiredAt DateTime?
}

enum ResourceType {
  ENVIRONMENT_VARIABLE
  SECRET
  OTHER
}

model EnvironmentVariable {
  id String @id @default(uuid())
  projectId String @default(uuid())
  key String
  value String
  target ResourceType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
} 

model Project {
  id String @id @default(uuid())
  userId String
  name String
  description String?
  framework Framework
  templateRepoUrl String?
  githubRepoUrl String?
  gitlabRepoUrl String?
  bitbucketRepoUrl String?
  vercelProjectId String?
  vercelProjectUrl String?
  status StatusOfWorkFlowExecution
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deployedAt DateTime?
  ownerId String

} 




